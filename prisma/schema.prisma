// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String    @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?    @db.Text
  access_token       String?    @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  // ↓@db.Textはテキストで宣言を指定
  id_token           String?    @db.Text
  session_state      String?

  // ↓createdAtはアカウントが作成された日が入る
  // ↓@mapでtableに保存する時のカラム名を変更できる
  createdAt          DateTime  @default(now()) @map(name: "created_at")
  updatedAt          DateTime  @default(now()) @map(name: "updated_at")

  // ↓外部キー接続を行っている
  // @relationでAccountとUserの関係を紐付けている
  // userIdはmodel AccountのuserIdを参照している
  // model idはUserのidを参照している
  // ↓※によって存在しないユーザーにアカウントを作成できないようにしている
  // onDelete: Cascadeは、Userが削除された場合に関連するAccountも削除されることを意味する
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  // ↓tableに保存する時に名前を変更して保存をする為の指定
  // 指定が無いと小文字で保存される
  // accountsで保存される
  @@map(name: "accounts")
}

// ↓サーバーへの負荷をなくすのでtokenの有無で処理を行い、supabaseではSessionを利用せず設定のみ行う
model Session {
  id           String   @id @default(cuid())
  userId       String
  expires      DateTime
  sessionToken String   @unique

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map(name: "sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  Post          Post[]

  // @uniqueは指定したフィールドの値が一意となる
  stripeCustomerId String? @unique @map(name: "stripe_customer_id")
  stripeSubscriptionId String? @unique @map(name: "stripe_subscription_id")
  stripePriceId String? @map(name: "stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map(name: "stripe_current_period_end")

  @@map(name: "users")
}

model VerificationRequest {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map(name: "verification_tokens")
}

model Post {
  // ↓@idは主キーを指定する
  id String @id @default(cuid())
  title String
  content Json?
  published Boolean @default(false)
  createdAt DateTime @default(now()) @map(name: "created_at")
  updateAt DateTime @default(now()) @map(name: "update_at")
  authorId String

  author User @relation(fields: [authorId], references: [id])

  @@map(name: "posts")
}